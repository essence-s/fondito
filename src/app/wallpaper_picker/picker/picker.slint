import { WallpaperCard } from "./card.slint";

export struct WallpaperItem {
    file-name: string,
    file-url: image,
    is-video: bool,
    dominant-color: string,
}

export global PickerAdapter {
    in-out property <[WallpaperItem]> wallpaper-model: [
        {
            file-name: "Mountains",
            file-url: @image-url("../../../../assets/icons/play-triangle.svg"),
            is-video: false,
            dominant-color: "#4A90D9"
        },
        {
            file-name: "Sunset",
            file-url: @image-url("../../../../assets/icons/play-triangle.svg"),
            is-video: false,
            dominant-color: "#FF6B35"
        },
        {
            file-name: "Forest",
            file-url: @image-url("../../../../assets/icons/play-triangle.svg"),
            is-video: false,
            dominant-color: "#2D8A4E"
        },
        {
            file-name: "Video 1",
            file-url: @image-url("../../../../assets/icons/play-triangle.svg"),
            is-video: true,
            dominant-color: "#A9A9A9"
        },
    ];
    in-out property <int> current-index;
    in-out property <int> wallpaper-count;

    callback navigate-left;
    callback navigate-right;
    callback apply-current;
    callback card-clicked(int);
}

export component Picker {
    callback escape-pressed;

    property <length> item-base-w: 500px;
    property <length> item-base-h: 420px;
    property <length> spacing: 10px;
    property <length> item-w-nc: item-base-w / 2;
    property <length> item-w-c: item-base-w * 3 / 2;
    property <length> total-w: (PickerAdapter.wallpaper-count - 1) * (item-w-nc + spacing) + item-w-c;
    property <length> target-x: viewport-clip.width / 2 - (PickerAdapter.current-index * (item-w-nc + spacing) + item-w-c / 2);
    property <length> content-x: viewport-clip.width <= 0px ? 0px : total-w <= viewport-clip.width ? (viewport-clip.width - total-w) / 2 : target-x > 0px ? 0px : target-x < viewport-clip.width - total-w ? viewport-clip.width - total-w : target-x;

    forward-focus: focus-scope;

    focus-scope := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.LeftArrow) { PickerAdapter.navigate-left(); accept; }
            else if (event.text == Key.RightArrow) { PickerAdapter.navigate-right(); accept; }
            else if (event.text == Key.Return) { PickerAdapter.apply-current(); accept; }
            else if (event.text == Key.Escape) { root.escape-pressed(); accept; }
            else { reject; }
        }

        viewport-clip := Rectangle {
            width: 100%;
            height: 100%;
            clip: true;
            background: transparent;
            VerticalLayout {
                alignment: center;
                content := Rectangle {
                    x: root.content-x;
                    width: root.total-w;

                    animate x {
                        duration: 400ms;
                        easing: ease-out;
                    }

                    HorizontalLayout {
                        spacing: spacing;

                        for item[idx] in PickerAdapter.wallpaper-model: WallpaperCard {
                            file-url: item.file-url;
                            is-video: item.is-video;
                            is-current: idx == PickerAdapter.current-index;

                            clicked => {
                                PickerAdapter.card-clicked(idx);
                            }
                        }
                    }
                }
            }
        }
    }
}
